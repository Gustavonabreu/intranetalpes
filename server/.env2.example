# App
NODE_ENV=production
PORT=3000
CORS_ORIGINS=https://intranet.seudominio.com
FRONTEND_BASE_URL=https://intranet.seudominio.com
AUTH_COOKIE_NAME=alpes_session

# MySQL principal (intranet)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=seu_usuario
MYSQL_PASSWORD=sua_senha
MYSQL_DATABASE=seu_banco

# GLPI DB (opcional para Meus Equipamentos)
GLPI_DB_HOST=127.0.0.1
GLPI_DB_PORT=3306
GLPI_DB_USER=seu_usuario
GLPI_DB_PASSWORD=sua_senha
GLPI_DB_DATABASE=glpi

# GLPI API (opcional)
GLPI_API_URL=https://glpi.seudominio.com/apirest.php
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=
GLPI_ADMIN_NUMBER_FIELD=16
GLPI_COMPUTER_USER_FIELD=70
GLPI_COMPUTER_USER_FIELDS=70
GLPI_USER_EMAIL_FIELD=5
GLPI_ACTIVE_PROFILE_ID=
GLPI_ACTIVE_ENTITY_ID=

# Fotos de usuário (opcional)
USER_PHOTO_BASE_URL=
USER_PHOTO_DEFAULT_EXT=jpg
USER_PHOTO_PROXY_ENABLED=false
USER_PHOTO_PROXY_REQUIRE_AUTH=true
USER_PHOTO_SOURCE_BASE_URL=
USER_PHOTO_PROXY_PUBLIC_BASE_URL=
USER_PHOTO_EXTENSIONS=jpg,jpeg,png

# Google Calendar (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
